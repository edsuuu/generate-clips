# LLM Provider padrão (local | claude | gemini | gpt | auto)
# auto = tenta Gemini, cai para local se falhar
LLM_PROVIDER=auto

# Ollama (provider local default — usado como fallback no modo auto)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:9b

# Google Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Endpoint base (REST v1beta). Override só se for usar proxy/mirror.
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
# Cascata de fallback: separados por vírgula. Se vazio, o provider gira entre
# gemini-flash-latest, gemini-2.5-flash, gemini-2.5-flash-lite,
# gemini-2.0-flash, gemini-2.0-flash-lite e gemini-2.5-pro.
GEMINI_FALLBACK_MODELS=
# Validator multimodal: manter apenas modelos completos (sem lite).
GEMINI_MULTIMODAL_FALLBACKS=
# Override de limites (opcional, JSON): {"gemini-2.5-flash": {"rpm": 6, "tpm": 250000, "rpd": 22}}
GEMINI_LIMITS_JSON=

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Whisper
WHISPER_MODEL=large-v3
# Engine: auto | mlx | faster. auto = MLX (GPU Metal) no macOS Apple Silicon,
# senao faster-whisper (CPU/CUDA). MLX usa greedy (sem beam search).
WHISPER_BACKEND=auto
# Override do repo MLX no HuggingFace. Vazio = derivado de WHISPER_MODEL
# (large-v3 -> mlx-community/whisper-large-v3-mlx). Ex. mais rapido:
# mlx-community/whisper-large-v3-turbo
WHISPER_MLX_MODEL=
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_LANGUAGE=pt
WHISPER_BEAM_SIZE=10
# Deixe vazio para evitar "leak" do prompt na transcrição (bug clássico do Whisper).
# Se preencher, use frases muito curtas e neutras de domínio (ex: "Batalha de rima.").
WHISPER_INITIAL_PROMPT=

# Output
TEMP_DIR=/tmp/auto-post
STORAGE_DISK=minio
MINIO_ENDPOINT=http://127.0.0.1:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=auto-post
MINIO_SECURE=false
PYTHON_API_TOKEN=
MAX_CUT_DURATION=80
MIN_CUT_DURATION=60
MIN_CUTS=6
MAX_CUTS=20
MIN_GAP_BETWEEN_CUTS=1.0

# FFmpeg render
# auto = h264_videotoolbox no macOS | h264_nvenc com NVIDIA | libx264 (fallback software).
FFMPEG_ENCODER=auto
# Decode por hardware: auto | none | videotoolbox | cuda | <hwaccel ffmpeg>.
# auto = videotoolbox no macOS; cuda no Linux/Windows com NVIDIA.
FFMPEG_HWACCEL=auto
FFMPEG_CRF=23
FFMPEG_PRESET=veryfast
FFMPEG_VIDEO_BITRATE=5M
# h264_nvenc: preset (p1=rapido/menor qualidade ... p7=lento/maior qualidade)
FFMPEG_NVENC_PRESET=p4
# h264_nvenc: quality target em modo VBR (0-51, menor = melhor; 20 ≈ CRF 23 do libx264)
FFMPEG_NVENC_CQ=20
# h264_nvenc: bitrate maximo no modo VBR
FFMPEG_NVENC_MAXRATE=8M
FFMPEG_MAX_CONCURRENT_RENDERS=1

# API HTTP
API_HOST=0.0.0.0
API_PORT=8765
WEBHOOK_TIMEOUT_SECONDS=30
WEBHOOK_FAIL_JOB_ON_ERROR=false

# Face tracking
FACE_TRACKING_ENABLED=true
FACE_TRACKING_SAMPLE_FPS=6
# Delegate de inferencia: auto | gpu | cpu.
# auto = GPU (OpenGL/EGL) no Linux/Windows com NVIDIA; CPU no macOS (Metal crasheia).
# gpu = forca GPU em qualquer plataforma (nao recomendado no macOS).
FACE_TRACKING_DELEGATE=auto
