# LLM Provider padrão (local | claude | gemini | gpt | auto)
# auto = tenta Gemini, cai para local se falhar
LLM_PROVIDER=auto

# Ollama (provider local default — usado como fallback no modo auto)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=gemma2:9b

# Google Gemini (recomendado — rápido e barato)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-latest
# Cascata de fallback: separados por vírgula. Quando o primário esgota cota
# ou retorna 429, o provider tenta o próximo automaticamente.
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite,gemini-3.1-flash-lite
# Override de limites (opcional, JSON): {"gemini-flash-latest": {"rpm": 10, "tpm": 500000, "rpd": 50}}
GEMINI_LIMITS_JSON=

# Anthropic Claude
ANTHROPIC_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o

# Whisper
WHISPER_MODEL=large-v3
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=auto
WHISPER_LANGUAGE=pt
WHISPER_BEAM_SIZE=10
# Deixe vazio para evitar "leak" do prompt na transcrição (bug clássico do Whisper).
# Se preencher, use frases muito curtas e neutras de domínio (ex: "Batalha de rima.").
WHISPER_INITIAL_PROMPT=

# Output
OUTPUT_DIR=./output
MAX_CUT_DURATION=80
MIN_CUT_DURATION=60
MIN_CUTS=6
MAX_CUTS=20
MIN_GAP_BETWEEN_CUTS=1.0

# Database (MySQL)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=auto_post
DB_USER=root
DB_PASSWORD=root

# API HTTP
API_HOST=0.0.0.0
API_PORT=8765

# Face tracking
FACE_TRACKING_ENABLED=true
FACE_TRACKING_SAMPLE_FPS=6
